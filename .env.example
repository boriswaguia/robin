# Gemini API key (for OCR + categorization & understanding)
# Get a free key at https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL connection string (for local dev — in Docker this is set automatically)
DATABASE_URL=postgresql://robin:your_db_password@localhost:5432/robin?schema=public

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Server port (optional, defaults to 3001)
PORT=3001

# Data-at-rest encryption key (AES-256-GCM) — exactly 64 hex characters (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-64-hex-chars

# Gmail Integration (OAuth2)
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Add https://your-domain.com/api/gmail/callback as an authorised redirect URI
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/gmail/callback

