datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  mail      Mail[]
}

model Mail {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl       String
  imageUrls      Json?    // Array of image URLs for multi-page documents
  extractedText  String?
  summary        String?
  sender         String?
  receiver       String?
  category       String?
  urgency        String?
  dueDate        String?
  amountDue      String?
  suggestedActions Json?
  keyDetails     Json?
  paymentDetails Json?
  actionableInfo Json?
  threadId       String?
  reminderAt     DateTime? // When to send a reminder notification
  reminderSent   Boolean  @default(false)
  status         String   @default("new")
  actionTaken    String?
  actionNote     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, category])
  @@index([userId, threadId])
  @@index([userId, sender])
  @@index([userId, receiver])
  @@index([reminderAt, reminderSent])
}
