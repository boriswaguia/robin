datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  name              String
  password          String
  gmailAccessToken  String?
  gmailRefreshToken String?
  gmailEmail        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  mail              Mail[]
  sharingFrom       ShareConnection[] @relation("SharingFrom")
  sharingTo         ShareConnection[] @relation("SharingTo")
}

model Mail {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl       String?  // null for text-only Gmail emails
  imageUrls      Json?    // Array of image URLs for multi-page documents
  extractedText  String?
  summary        String?
  sender         String?
  receiver       String?
  category       String?
  urgency        String?
  dueDate        String?
  amountDue      String?
  suggestedActions Json?
  keyDetails     Json?
  paymentDetails Json?
  actionableInfo Json?
  threadId       String?
  reminderAt     DateTime? // When to send a reminder notification
  reminderSent   Boolean  @default(false)
  status         String   @default("new")
  actionTaken    String?
  actionNote     String?
  source         String   @default("scan") // 'scan' | 'gmail'
  gmailMessageId String?  // prevents duplicate imports
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  shares         MailShare[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, category])
  @@index([userId, threadId])
  @@index([userId, sender])
  @@index([userId, receiver])
  @@index([reminderAt, reminderSent])
  @@unique([userId, gmailMessageId])
}

// ── Sharing ──────────────────────────────────────────────────────────────────

// Directional invite: fromUser wants to share mail with toUser
model ShareConnection {
  id               String   @id @default(uuid())
  fromUserId       String
  toUserId         String
  fromUser         User     @relation("SharingFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser           User     @relation("SharingTo",   fields: [toUserId],   references: [id], onDelete: Cascade)
  status           String   @default("pending") // pending | accepted
  sharedCategories Json?    // null = none auto-shared; ["bill","medical"] = auto-share those categories
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@index([fromUserId])
}

// Explicit per-item share override
model MailShare {
  id               String   @id @default(uuid())
  mailId           String
  mail             Mail     @relation(fields: [mailId], references: [id], onDelete: Cascade)
  sharedByUserId   String
  sharedWithUserId String
  createdAt        DateTime @default(now())

  @@unique([mailId, sharedWithUserId])
  @@index([sharedWithUserId])
  @@index([sharedByUserId])
}
