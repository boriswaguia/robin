# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://robin:yourpassword@localhost:5432/robin?schema=public
JWT_SECRET=change-me-to-a-long-random-string
ENCRYPTION_KEY=32-byte-hex-key-for-aes-256-gcm
